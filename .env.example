# Environment Configuration Example
# Copy this file to .env and fill in your values

# Application
REACT_APP_NAME=Afleet Store
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# API Configuration
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_API_TIMEOUT=10000

# Security
REACT_APP_JWT_SECRET=your-super-secret-jwt-key-here
REACT_APP_ENCRYPTION_KEY=your-encryption-key-here
REACT_APP_CSRF_TOKEN_NAME=_token

# Database (for future backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afleet_store
DB_USER=root
DB_PASSWORD=your-database-password

# Email Configuration (for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@afleetstore.com
MAIL_FROM_NAME="Afleet Store"

# File Upload
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Rate Limiting
REACT_APP_RATE_LIMIT_REQUESTS=100
REACT_APP_RATE_LIMIT_WINDOW=900000

# Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
REACT_APP_FACEBOOK_PIXEL_ID=FB_PIXEL_ID

# Payment Gateway (for future integration)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id

# SMS Service (for OTP)
REACT_APP_SMS_API_KEY=your_sms_api_key
REACT_APP_SMS_SENDER_ID=AFLEET

# CDN Configuration
REACT_APP_CDN_URL=https://cdn.afleetstore.com
REACT_APP_IMAGES_BASE_URL=https://images.afleetstore.com

# Social Media
REACT_APP_FACEBOOK_URL=https://facebook.com/afleetstore
REACT_APP_TWITTER_URL=https://twitter.com/afleetstore
REACT_APP_INSTAGRAM_URL=https://instagram.com/afleetstore

# Support
REACT_APP_SUPPORT_EMAIL=support@afleetstore.com
REACT_APP_SUPPORT_PHONE=+201234567890
REACT_APP_SUPPORT_WHATSAPP=+201234567890

# Features Flags
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_CHAT_SUPPORT=false
REACT_APP_ENABLE_PWA=true

# Development Tools
REACT_APP_DEBUG_MODE=false
REACT_APP_SHOW_PERFORMANCE_METRICS=false

# Security Headers (for backend)
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_CONTENT_TYPE_NOSNIFF=true
SECURITY_FRAME_DENY=true
SECURITY_XSS_PROTECTION=true

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://afleetstore.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Session Configuration
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# Backup Configuration
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# Monitoring
MONITORING_ENABLED=true
LOG_LEVEL=info
ERROR_REPORTING_ENABLED=true

# Cache Configuration
CACHE_DRIVER=redis
CACHE_TTL=3600
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Queue Configuration (for background jobs)
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database

# Localization
DEFAULT_LOCALE=ar
FALLBACK_LOCALE=en
SUPPORTED_LOCALES=ar,en

# Timezone
APP_TIMEZONE=Africa/Cairo

# SSL Configuration
SSL_ENABLED=true
SSL_REDIRECT=true
SSL_CERTIFICATE_PATH=/etc/ssl/certs/afleetstore.crt
SSL_PRIVATE_KEY_PATH=/etc/ssl/private/afleetstore.key
